---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company } from '../data/company';
import { productCategories } from '../data/product-categories';

const projectHighlights = [
  {
    title: 'King Salman Project',
    image: '/images/projects/king-salman.png',
    label: 'Project reference'
  },
  {
    title: 'Solitaire Mall',
    image: '/images/projects/solitaire-mall.jpg',
    label: 'Commercial project'
  },
  {
    title: 'Trilogy Project',
    image: '/images/projects/trilogy-project.jpg',
    label: 'Project reference'
  }
];
---

<BaseLayout title={company.name} description={company.positioning}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">HVAC manufacturing and engineering</p>
        <h1>Air movement, air distribution, filtration, and fire-safety systems built for demanding projects.</h1>
        <p class="lead">{company.positioning}</p>
        <div class="actions">
          <a class="button" href="/products/">Explore Products</a>
          <a class="button secondary" href="/contact/">Request Support</a>
        </div>
      </div>
      <div class="hero-media">
        <img src="/images/projects/king-salman.png" alt="Klimacontra project reference" />
        <div class="hero-panel">
          <span>Product Catalogue</span>
          <strong>{productCategories.length}</strong>
          <p>Primary product families ready to be converted into structured product pages.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <p class="eyebrow">Product families</p>
      <h2>Organized around how customers search and specify HVAC products.</h2>
      <div class="grid category-grid">
        {productCategories.map((category) => (
          <article class="card">
            <h3>{category.title}</h3>
            <p>{category.description}</p>
            <small>{category.children.join(' · ')}</small>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Selected references</p>
      <h2>Legacy project images migrated into the clean rebuild structure.</h2>
      <div class="grid project-grid">
        {projectHighlights.map((project) => (
          <article class="project-card">
            <img src={project.image} alt={project.title} />
            <div>
              <span>{project.label}</span>
              <h3>{project.title}</h3>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 110px 0 90px;
    background:
      radial-gradient(circle at 78% 20%, rgba(247, 201, 72, 0.25), transparent 28%),
      linear-gradient(135deg, #f7fafb 0%, #ffffff 48%, #eaf1f5 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 42px;
    align-items: center;
  }

  h1 {
    font-size: clamp(2.8rem, 6vw, 5.7rem);
    letter-spacing: -0.06em;
  }

  .lead {
    max-width: 720px;
    color: var(--color-muted);
    font-size: 1.14rem;
  }

  .actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .hero-media {
    display: grid;
    gap: 18px;
  }

  .hero-media > img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
  }

  .hero-panel {
    border-radius: var(--radius-md);
    padding: 24px;
    background: var(--color-primary);
    color: white;
    box-shadow: var(--shadow-soft);
  }

  .hero-panel span {
    color: var(--color-accent);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
  }

  .hero-panel strong {
    display: block;
    margin: 10px 0;
    font-size: 3.6rem;
    line-height: 1;
  }

  .hero-panel p {
    color: rgba(255, 255, 255, 0.78);
  }

  .category-grid,
  .project-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 32px;
  }

  small {
    color: var(--color-muted);
    font-weight: 700;
  }

  .project-card {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: white;
    box-shadow: 0 8px 24px rgba(11, 23, 32, 0.05);
  }

  .project-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .project-card div {
    padding: 22px;
  }

  .project-card span {
    color: var(--color-teal);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .category-grid,
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
