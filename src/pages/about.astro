---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company } from '../data/company';
---

<BaseLayout title="About" description="About Klimacontra and its HVAC manufacturing capabilities.">
  <section class="section">
    <div class="container page-head">
      <p class="eyebrow">About Klimacontra</p>
      <h1>Engineering-led HVAC manufacturing for regional projects.</h1>
      <p>{company.positioning}</p>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container grid values-grid">
      {company.values.map((value) => (
        <article class="card">
          <h2>{value}</h2>
          <p>Rewrite this block with KlimaContra-specific evidence, capabilities, standards, and project examples.</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { max-width: 840px; }
  h1 { font-size: clamp(2.4rem, 5vw, 4.8rem); }
  .values-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  @media (max-width: 900px) { .values-grid { grid-template-columns: 1fr; } }
</style>
