---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { productCategories } from '../../../data/product-categories';

export async function getStaticPaths() {
  const products = await getCollection('products');

  return products.map((entry) => {
    const category = productCategories.find((item) => item.slug === entry.data.category);

    return {
      params: {
        category: entry.data.category,
        product: entry.slug
      },
      props: {
        entry,
        category
      }
    };
  });
}

const { entry, category } = Astro.props;
const { Content } = await entry.render();
const product = entry.data;
---

<BaseLayout title={`${product.title}${product.model ? ` - ${product.model}` : ''}`} description={product.summary}>
  <section class="section product-hero">
    <div class="container product-grid">
      <div>
        <p class="eyebrow">{category?.title ?? product.category}</p>
        <h1>{product.title}</h1>
        {product.model && <p class="model">{product.model}</p>}
        <p class="summary">{product.summary}</p>
      </div>
      {product.image && (
        <img class="product-image" src={product.image} alt={`${product.title} ${product.model ?? ''}`} />
      )}
    </div>
  </section>

  <section class="section section-muted">
    <div class="container detail-grid">
      <article class="card">
        <h2>Applications</h2>
        <ul>
          {product.applications.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card">
        <h2>Features</h2>
        <ul>
          {product.features.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container content-body">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .product-grid {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: 42px;
    align-items: center;
  }

  h1 {
    font-size: clamp(2.6rem, 5vw, 5rem);
  }

  .model {
    display: inline-flex;
    margin: 8px 0 18px;
    padding: 8px 12px;
    border-radius: 999px;
    background: var(--color-primary);
    color: white;
    font-weight: 800;
  }

  .summary {
    max-width: 720px;
    color: var(--color-muted);
    font-size: 1.1rem;
  }

  .product-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
    background: white;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  ul {
    margin: 0;
    padding-left: 18px;
    color: var(--color-muted);
  }

  .content-body {
    max-width: 840px;
  }

  @media (max-width: 900px) {
    .product-grid,
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
