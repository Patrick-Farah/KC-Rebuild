---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { productCategories } from '../../data/product-categories';
---

<BaseLayout title="Products" description="Klimacontra product families organized for the website rebuild.">
  <section class="section">
    <div class="container intro">
      <p class="eyebrow">Products</p>
      <h1>Structured product catalogue foundation.</h1>
      <p>Use this page as the top-level catalogue. Each product family should later connect to category pages and individual product detail pages.</p>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container grid product-grid">
      {productCategories.map((category) => (
        <article class="card">
          <p class="eyebrow">/{category.slug}</p>
          <h2>{category.title}</h2>
          <p>{category.description}</p>
          <ul>
            {category.children.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .intro { max-width: 820px; }
  h1 { font-size: clamp(2.4rem, 5vw, 4.8rem); }
  .product-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  ul { margin: 18px 0 0; padding-left: 18px; color: var(--color-muted); }
  @media (max-width: 800px) { .product-grid { grid-template-columns: 1fr; } }
</style>
